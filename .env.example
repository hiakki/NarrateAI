# ============================================
# NarrateAI — Environment Variables
# ============================================
# Copy this file to .env.local and fill in values
# cp .env.example .env.local

# --- App ---
PORT=3000                                  # Next.js server port
# Next.js binds to 127.0.0.1 only (see package.json dev/start). Use nginx on 443 → proxy to http://127.0.0.1:$PORT
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Must match PORT (or tunnel URL in production)
NODE_ENV=development

# --- Scheduler: Pre-build window ---
BUILD_ALL_TIME=04:00                       # HH:MM — build all videos at this time daily
BUILD_ALL_TIMEZONE=Asia/Kolkata            # Timezone for the build window

# --- Tunneling (for pnpm tunnel / pnpm dev:tunnel) ---
# TUNNEL_PROVIDER=cloudflare   # or localtunnel (default: cloudflare)
# TUNNEL_SUBDOMAIN=            # optional; only for localtunnel (e.g. myapp → https://myapp.loca.lt)

# --- Owner Account ---
# The first account matching this email is auto-promoted to "owner" role.
# Register normally via the app, then the seed script promotes this email.
OWNER_EMAIL=            # Your email (e.g., you@narrateai.com)

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/narrateai

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Authentication (NextAuth.js) ---
NEXTAUTH_SECRET=          # Generate: openssl rand -base64 32
# NEXTAUTH_URL is auto-derived from NEXT_PUBLIC_APP_URL — no need to set it separately
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI Providers (platform keys) ---
# Required: powers Gemini Flash (script), Gemini TTS, Gemini Imagen
GEMINI_API_KEY=           # https://aistudio.google.com/apikey

# Optional: enables GPT-4o Mini (script) + DALL-E 3 (images)
OPENAI_API_KEY=           # https://platform.openai.com/api-keys

# Optional: enables DeepSeek V3 (script)
DEEPSEEK_API_KEY=         # https://platform.deepseek.com/

# Optional: enables ElevenLabs TTS
ELEVENLABS_API_KEY=       # https://elevenlabs.io/

# Optional: enables Flux + Kolors image generation via Replicate
REPLICATE_API_TOKEN=      # https://replicate.com/account/api-tokens

# --- I2V Providers (comma-separated keys for rotation) ---
# I2V provider is chosen via the UI (Settings → Image-to-Video). These are just the API keys.
# Pollinations: free tier ~10 pollen/day. Get key at https://enter.pollinations.ai
# POLLINATIONS_API_KEY=key1,key2,key3
#
# Freepik (Kling v2): 5 EUR free trial credits (~15-25 clips). Get key at https://freepik.com/developers/dashboard
# FREEPIK_API_KEY=your_freepik_key
#
# HuggingFace: also supports comma-separated keys (see above)


# Optional: enables Qwen (script) + CosyVoice (TTS) via Alibaba DashScope
DASHSCOPE_API_KEY=        # https://dashscope.console.aliyun.com/

# Optional: free story/script generation via Hugging Face (English & Hindi)
# Same key powers: HF story LLM, HF TTS, HF Image, HF I2V, AI BGM (MusicGen), AI SFX (AudioGen).
# Create a token at https://huggingface.co/settings/tokens
# Supports comma-separated keys for rotation: key1,key2,key3
HUGGINGFACE_API_KEY=      # or HUGGINGFACE_API_TOKEN / HF_TOKEN
#
# One-time: Hugging Face requires you to enable which models can run (per account).
# The token alone is not enough — go to https://huggingface.co/settings/inference-providers
# and enable at least one provider that serves your model. See docs/huggingface-token-vs-providers.md.
# HF_STORY_MODEL=...      # optional; default Qwen 7B
# HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell  # optional; default FLUX.1-schnell

# Optional: enables Fish Audio TTS (free tier available)
FISH_AUDIO_API_KEY=       # https://fish.audio/

# Optional: enables Together.ai image generation (free Flux Schnell tier)
TOGETHER_API_KEY=         # https://api.together.xyz/settings/api-keys

# Optional: enables SiliconFlow image gen + Wan I2V ($1 free credits)
SILICONFLOW_API_KEY=      # https://siliconflow.cn/

# Optional: enables deAPI LTX-2.3 I2V ($5 free credits, ~100 clips)
DEAPI_API_KEY=            # https://deapi.ai/

# Optional: enables PixVerse V5 I2V (free plan available, good quality)
PIXVERSE_API_KEY=         # https://platform.pixverse.ai/

# Optional: enables Leonardo.ai image generation (150 free/day)
LEONARDO_API_KEY=         # https://app.leonardo.ai/api-access

# Optional: enables Ideogram image generation (best text-in-image)
IDEOGRAM_API_KEY=         # https://developer.ideogram.ai/

# --- Local server (single var for LOCAL_LLM + LOCAL_BACKEND) ---
# LOCAL_BACKEND_URL = base URL of your server. Default: http://localhost:8000
#   - LOCAL_BACKEND (story/TTS/image/video): POST {base}/api/story, /api/tts, /api/image, /api/video
#   - LOCAL_LLM (OpenAI-compatible chat):    POST {base}/v1/chat/completions
# LOCAL_BACKEND_URL=http://localhost:8000
# Or e.g. a tunnel: LOCAL_BACKEND_URL=https://your-subdomain.trycloudflare.com
#
# Optional overrides for LOCAL_LLM only (leave unset to use LOCAL_BACKEND_URL + /v1):
# LOCAL_LLM_URL=           # override chat base (e.g. http://localhost:11434/v1)
# LOCAL_LLM_MODEL=        # model name (default: default)
# LOCAL_LLM_API_KEY=     # not-needed for Ollama
# LOCAL_BACKEND_STORY_TIMEOUT_MS=600000   # timeout for /api/story (default 10 min; increase for slow/large models)

# --- Video Generation ---
# When all I2V providers are exhausted, fall back to static images (Ken Burns) instead of failing.
# Set to "false" to FAIL the video instead of falling back.
# I2V_FALLBACK_ENABLED=true

# I2V Budget: max clips per video (default: 0 = all scenes). Prioritizes hook (scene 0).
# Set to 2-3 to conserve credits — every video gets a video hook + 1-2 more scenes.
# I2V_MAX_CLIPS_PER_VIDEO=2

# --- Clip Repurpose Pipeline ---
# How many clip posts per platform per day (optimizer enables top N niches to reach this)
DAILY_CLIP_POSTS_PER_PLATFORM=6
# YouTube Data API key (optional, for trending/CC discovery). NOT the same as GEMINI_API_KEY.
# YOUTUBE_API_KEY=AIza...
# Path to Netscape-format cookies.txt for FB/IG/TikTok downloads (yt-dlp --cookies)
# Export from browser using "Get cookies.txt LOCALLY" extension
# YTDLP_COOKIES_FILE=/path/to/cookies.txt
# Custom yt-dlp binary path (defaults to "yt-dlp" on PATH)
# YTDLP_PATH=yt-dlp

# --- Media Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=narrateai-media
R2_PUBLIC_URL=            # Public bucket URL for CDN delivery

# --- Media Storage (AWS S3 Alternative) ---
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=        # sk_test_... or sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=  # pk_test_... or pk_live_...
STRIPE_WEBHOOK_SECRET=    # whsec_...

# --- Social Media: TikTok ---
TIKTOK_CLIENT_KEY=        # https://developers.tiktok.com/
TIKTOK_CLIENT_SECRET=

# --- Social Media: Instagram ---
INSTAGRAM_APP_ID=         # https://developers.facebook.com/
INSTAGRAM_APP_SECRET=

# --- Social Media: YouTube ---
YOUTUBE_CLIENT_ID=        # https://console.cloud.google.com/
YOUTUBE_CLIENT_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=           # https://resend.com/

# --- Monitoring ---
SENTRY_DSN=               # https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=  # https://plausible.io/
